{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/backend.js": {
      "maxDuration": 20
    }
  },
  "rewrites": [
    {
      "source": "/backend-api/(.*)",
      "destination": "/api/backend?path=$1"
    },
    {
      "source": "/backend-media/(.*)",
      "destination": "https://api.missmisteruniversitybenin.com/api/public/media/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
