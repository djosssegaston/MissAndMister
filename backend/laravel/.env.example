APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=http://localhost:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOWED_ORIGINS_PATTERN=.*

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

PROD_ADMIN_NAME=
PROD_ADMIN_EMAIL=
PROD_ADMIN_PHONE=
PROD_ADMIN_PASSWORD=
PROD_ADMIN_ROLE=superadmin
PROD_ADMIN_STATUS=active

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_REKOGNITION_VERSION=latest

MEDIA_DRIVER=local
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=missandmister
CLOUDINARY_TIMEOUT=30

# FedaPay is configured server-side only. Do not manage these keys from the admin dashboard.
FEDAPAY_PUBLIC_KEY=
FEDAPAY_SECRET_KEY=
FEDAPAY_WEBHOOK_SECRET=
FEDAPAY_ENVIRONMENT=sandbox
FEDAPAY_WEBHOOK_ASYNC=true
FEDAPAY_WEBHOOK_QUEUE=default
FEDAPAY_READ_MODEL_WARM_ENABLED=false
FEDAPAY_AUDIT_IGNORE_REFERENCES=

CANDIDATE_IMAGE_DISK=public
CANDIDATE_IMAGE_QUEUE=images
CANDIDATE_IMAGE_ASYNC_PROCESSING=false
CANDIDATE_IMAGE_FACE_PROVIDER=none
CANDIDATE_IMAGE_REQUIRE_FACE=false
CANDIDATE_IMAGE_MIN_WIDTH=500
CANDIDATE_IMAGE_MIN_HEIGHT=500
CANDIDATE_IMAGE_BLUR_THRESHOLD=15
CANDIDATE_IMAGE_WEBP_QUALITY=92
CANDIDATE_IMAGE_BACKGROUND_COLOR=#000000

VITE_APP_NAME="${APP_NAME}"
